# Ignore all top-level files/folders by default.
/*

# Keep only these folders in scope.
!/backend/
!/frontend/

# Keep this file tracked.
!/.gitignore

# Dependencies
**/node_modules/

# Build outputs
**/build/
**/dist/
**/coverage/
**/.vite/

# Environment files
**/.env
**/.env.*
!**/.env.example

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# OS/Editor
**/.DS_Store
**/Thumbs.db
**/.vscode/
**/.idea/

# Local tooling
**/.codex
